# Telegram Bot Token - Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui

# IDs de usuario de Telegram permitidos, separados por comas
TELEGRAM_ALLOWED_USER_IDS=tu_id_aqui

# AI API Keys (at least one is required)
# Get from https://console.groq.com
GROQ_API_KEY=tu_token_aqui

# Get from https://openrouter.ai
OPENROUTER_API_KEY=tu_token_aqui

# Optional: Ollama local instance
OLLAMA_URL=http://localhost:11434

# Búsqueda web (Tavily) - https://tavily.com
TAVILY_API_KEY=tu_token_aqui

# Lectura de URLs (Firecrawl) - https://firecrawl.dev
FIRECRAWL_API_KEY=tu_token_aqui

# Firebase Admin - variables individuales
FIREBASE_PROJECT_ID=tu_token_aqui
FIREBASE_CLIENT_EMAIL=tu_token_aqui
FIREBASE_PRIVATE_KEY=tu_token_aqui

# Firebase Admin - alternativa: JSON completo del service account en base64
# (evita problemas con \n en la private key; si se define, tiene prioridad sobre las 3 de arriba)
FIREBASE_SERVICE_ACCOUNT_B64=tu_token_aqui

# Environment
NODE_ENV=production
PORT=3000

# Optional: Enable HTTP health check
ENABLE_HTTP=true
